# ============================================================
# HITL-AP Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ─── Database (PostgreSQL Audit Logger) ─────────────────────
DATABASE_URL=postgresql://hitlap:hitlap_dev@localhost:5432/hitlap

# ─── Message Queue (RabbitMQ Escalation Manager) ────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_QUEUE_NAME=hitlap_escalation_queue
RABBITMQ_EXCHANGE=hitlap_exchange

# ─── Policy Engine (Open Policy Agent) ──────────────────────
OPA_URL=http://localhost:8181
OPA_POLICY_PACKAGE=hitlap
OPA_POLICY_PATH=aocp/policies/hitlap_policy.rego

# ─── AOCP Risk Analyzer ──────────────────────────────────────
AOCP_RISK_ANALYZER_URL=http://localhost:8000
AOCP_RISK_ANALYZER_PORT=8000

# ─── Cryptographic Audit Signing ────────────────────────────
# IMPORTANT: Change this to a cryptographically random string (min 32 chars)
# In production use a secrets manager (AWS Secrets Manager, HashiCorp Vault)
AOCP_HMAC_SECRET=change_this_to_a_secure_random_secret_minimum_32_chars

# ─── AOCP Deployment Mode ────────────────────────────────────
# Options: inline | advisory | hybrid (recommended default)
AOCP_MODE=hybrid

# ─── Risk Scoring Thresholds ────────────────────────────────
# Risk scores range 0.0 (no risk) to 1.0 (critical risk)
# Actions scoring above AOCP_RISK_THRESHOLD trigger escalation
AOCP_RISK_THRESHOLD=0.70
AOCP_CRITICAL_THRESHOLD=0.90

# ─── Intervention Latency Target ────────────────────────────
# Programmatic routing overhead target in milliseconds
# Paper target: <200ms (achieved: 142.3ms ± 18.5ms)
AOCP_IL_TARGET_MS=200

# ─── Agent / LLM Configuration ──────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=hitlap-evaluation

# ─── Evaluation Configuration ────────────────────────────────
EVALUATION_RUNS=50
EVALUATION_RESULTS_DIR=evaluation/results

# ─── Logging ─────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── SLA / Timeout Configuration ────────────────────────────
# Time in seconds before Escalation Manager falls back to safe halt
ESCALATION_SLA_TIMEOUT_SECONDS=300
ESCALATION_FALLBACK_POLICY=reject
